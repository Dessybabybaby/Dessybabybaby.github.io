---
import BgGrid from "@/components/assets/BgGrid.astro";

const competencies = [
  {
    title: "Security Automation",
    description:
      "Architecting automated workflows using n8n and Python to streamline threat intelligence, vulnerability monitoring, and incident response tasks.",
  },
  {
    title: "Infrastructure Defense",
    description:
      "Hardening Linux and Windows environments, configuring firewalls, and implementing network security protocols to ensure system integrity.",
  },
  {
    title: "OSINT & Reconnaissance",
    description:
      "Utilizing advanced open-source intelligence techniques for data harvesting, credential exposure monitoring, and threat surface analysis.",
  },
  {
    title: "Compliance & Auditing",
    description:
      "Conducting systematic reviews of IT infrastructure to identify security gaps and ensure alignment with industry standards and best practices.",
  },
];
---

<section class="border-white/10 border-b divide-y divide-white/10 bg-[#0a0a0a]">
  <div class="px-8 py-6 relative">
    <BgGrid />
    <h2 class="text-3xl font-black text-white uppercase tracking-tighter">
      Technical // Capabilities
    </h2>
  </div>
  <div
    class="text-white gap-0 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-white/10"
  >
    {
      competencies.map(({ title, description }) => (
        <div class="p-8 group hover:bg-white/[0.02] transition-colors duration-500">
          <h3 class="text-sm uppercase font-bold text-[#ff5f1f] tracking-widest font-mono">{title}</h3>
          <p class="mt-4 text-white/50 text-sm leading-relaxed font-light">{description}</p>
        </div>
      ))
    }
  </div>
</section>