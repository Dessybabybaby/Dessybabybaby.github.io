---
import BgGrid from "@/components/assets/BgGrid.astro";

const projects = [
  {
    name: "CVE-RSS Alert System",
    description: "Automated vulnerability monitoring using n8n to parse NVD RSS feeds and trigger real-time critical alerts.",
    link: "https://github.com/Dessybabybaby/cve-rss-alert-system",
    tag: "Threat Intelligence"
  },
  {
    name: "Secret Exposure Pipeline",
    description: "Security scanner built with n8n to detect exposed credentials and sensitive data in public GitHub repositories.",
    link: "https://github.com/Dessybabybaby/secret-exposure-monitoring-pipeline",
    tag: "DevSecOps"
  },
  {
    name: "OSINT Email Harvester",
    description: "Automated OSINT tool for extracting and validating email addresses from public web pages for security research.",
    link: "https://github.com/Dessybabybaby/osint-email-harvester",
    tag: "OSINT"
  },
  {
    name: "Log File Analyzer",
    description: "Automated analysis system detecting brute force attempts and security anomalies within server logs.",
    link: "https://github.com/Dessybabybaby/log-file-analyzer",
    tag: "SecOps"
  },
  {
    name: "HTB Progress Tracker",
    description: "Automation workflow to scrape HackTheBox profile data and generate security achievement dashboards.",
    link: "https://github.com/Dessybabybaby/htb-progress-tracker",
    tag: "Security Research"
  },
  {
    name: "Email Task Automation",
    description: "Operational workflow converting support and security emails into actionable incident tasks via n8n.",
    link: "https://github.com/Dessybabybaby/email-task-automation",
    tag: "IT Ops"
  }
];
---

<section class="border-b border-white/10 bg-[#0a0a0a]">
  <div class="px-8 py-12 relative border-b border-white/10">
    <BgGrid />
    <p class="text-[#ff5f1f] font-mono text-[10px] mb-4 tracking-[0.4em] uppercase opacity-60 relative">
      // Selected Security Pipelines
    </p>
    <h2 class="text-3xl md:text-5xl font-bold text-white uppercase tracking-tighter relative">
      Technical Projects
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-white/10 border-white/10">
    {
      projects.map((project) => (
        <a 
          href={project.link} 
          target="_blank" 
          class="p-8 group hover:bg-white/[0.02] transition-all duration-500 flex flex-col justify-between min-h-[300px]"
        >
          <div>
            <div class="flex justify-between items-start mb-6">
              <span class="text-[10px] font-mono text-white/30 uppercase tracking-widest border border-white/10 px-2 py-1">
                {project.tag}
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-white/20 group-hover:text-[#ff5f1f] transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg>
            </div>
            <h3 class="text-white text-xl font-bold uppercase tracking-tight mb-4 group-hover:text-[#ff5f1f] duration-300">
              {project.name}
            </h3>
            <p class="text-white/50 text-sm font-light leading-relaxed">
              {project.description}
            </p>
          </div>
          
          <div class="mt-8 flex items-center gap-2 text-[10px] font-mono text-[#ff5f1f] uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
            <span>View technical source</span>
            <span class="animate-pulse">_</span>
          </div>
        </a>
      ))
    }
  </div>
</section>