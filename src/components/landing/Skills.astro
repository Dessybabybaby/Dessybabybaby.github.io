---
import BgGrid from "@/components/assets/BgGrid.astro";

const skillCategories = [
  {
    title: "Security & DevSecOps",
    skills: ["Vulnerability Monitoring", "Credential Secret Scanning", "OSINT Recon", "Threat Intelligence", "Log Analysis", "Zero Trust Architecture"]
  },
  {
    title: "Automation & Scripting",
    skills: ["n8n Workflows", "Python", "JavaScript", "IT Automation", "Data Pipelines", "API Integration", "Regex Optimization"]
  },
  {
    title: "Strategic & Management",
    skills: ["Scrum / Agile", "Productivity Analytics", "Technical Mentorship", "Stakeholder Management", "ICT Consultation", "Cyberpsychology"]
  }
];
---

<section id="skills" class="border-b border-white/10 bg-[#0a0a0a] overflow-hidden">
  <div class="p-8 md:p-16 relative">
    <BgGrid />
    
    <div class="relative z-10">
      <p class="text-[#ff5f1f] font-mono text-[10px] mb-4 tracking-[0.4em] uppercase opacity-60">
        // Skills
      </p>
      
      <h2 class="text-white font-black uppercase tracking-tighter lg:text-7xl text-3xl leading-none mb-20">
        CORE <span class="text-white/20">COMPETENCIES.</span>
      </h2>

      <div class="grid grid-cols-1 lg:grid-cols-3 divide-y lg:divide-y-0 lg:divide-x divide-white/10 border-t border-b border-white/10">
        {skillCategories.map((category) => (
          <div class="py-12 lg:px-10 first:pl-0 last:pr-0 group">
            <h3 class="text-white font-mono text-xs uppercase tracking-[0.3em] mb-10 flex items-center gap-3">
              <span class="h-1.5 w-1.5 bg-[#ff5f1f]"></span>
              {category.title}
            </h3>
            
            <div class="flex flex-wrap gap-2">
              {category.skills.map((skill) => (
                <div class="px-3 py-1.5 border border-white/5 bg-white/[0.02] transition-all duration-300 hover:border-[#ff5f1f]/30">
                  <span class="text-white/40 text-[10px] font-mono uppercase tracking-tight group-hover:text-white/70 transition-colors">
                    {skill}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12">
        <p class="text-white/20 font-mono text-[9px] uppercase tracking-[0.5em]">
        </p>
      </div>
    </div>
  </div>
</section>