---
const messages = [
  "Incident Response",
  "System Hardening",
  "Threat Intelligence",
  "Network Integrity",
  "Automation Architect",
  "SecOps Deployment",
  "Infrastructure Audit",
  "Zero Trust Framework",
  "Compliance Verified",
  "Ready for Deployment",
];
const marqueeItems = [...messages, ...messages]; // Duplicate for seamless loop
---

<section class="border-white/10 border-y bg-black">
  <div class="overflow-hidden py-3 relative text-white/40">
    <div
      aria-hidden="true"
      class="absolute inset-0 z-10 pointer-events-none"
    >
      <div
        class="absolute left-0 w-24 h-full bg-gradient-to-r from-black via-transparent"
      >
      </div>
      <div
        class="absolute right-0 w-24 h-full bg-gradient-to-l from-black via-transparent"
      >
      </div>
    </div>

    <div
      class="flex w-max animate-marquee gap-8 whitespace-nowrap font-mono text-[10px] tracking-[0.3em] uppercase items-center"
    >
      {
        marqueeItems.map((msg, index) => (
          <div class="flex items-center gap-8">
            <span class="hover:text-[#ff5f1f] duration-300 transition-colors cursor-default">{msg}</span>
            {index !== marqueeItems.length - 1 && (
              <span class="text-[#ff5f1f] opacity-50" aria-hidden="true">/</span>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>